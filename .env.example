# ─── Database ────────────────────────────────────────────────────────────────
# Provided automatically by Railway's MySQL plugin — copy the value from there
DATABASE_URL=mysql://user:password@host:3306/dbname

# ─── Auth ────────────────────────────────────────────────────────────────────
# Random secret string used to sign JWT / session cookies (generate one below)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# ─── OAuth / Manus ───────────────────────────────────────────────────────────
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_OAUTH_PORTAL_URL=

# ─── Manus Forge (file storage) ──────────────────────────────────────────────
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# ─── App identity ────────────────────────────────────────────────────────────
VITE_APP_ID=

# ─── Vite frontend Forge keys (same as server-side Forge, if applicable) ─────
VITE_FRONTEND_FORGE_API_URL=
VITE_FRONTEND_FORGE_API_KEY=

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=production
# PORT is set automatically by Railway — do not override it here
